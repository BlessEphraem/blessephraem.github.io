{
  "name": "blessephraem-local",
  "version": "1.0.0",
  "private": true,
  "workspaces": ["Wiki", "Blog"],
  "scripts": {
    "start:wiki": "npm run start -w wiki",
    "start:blog": "npm run start -w blog",
    "build:wiki": "npm run build -w wiki",
    "build:blog": "npm run build -w blog",
    "build": "npm run build:wiki && npm run build:blog",
    "clear": "npm run clear -w wiki && npm run clear -w blog"
  },
  "dependencies": {
    "express": "^4.18.2",
    "http-proxy-middleware": "^2.0.6"
  },
  "engines": {
    "node": ">=20.0"
  }
}
